# Aletheia runtime environment - copy to instance/config/env
# Must be systemd EnvironmentFile compatible (no export, no variable refs)

# Required when not using an instance credential file
ANTHROPIC_API_KEY=

# Optional. ALETHEIA_ROOT is always the instance root, never a source tree or
# install prefix. The CLI -r/--instance-root flag wins when both are supplied.
# ALETHEIA_ROOT=/srv/aletheia/instance

# Optional. Shared helper scripts use ALETHEIA_BIN when they need an executable.
# ALETHEIA_BIN=/usr/local/bin/aletheia

# Embedding (optional - candle uses local models, no API key needed)
VOYAGE_API_KEY=

# Optional - shared/bin tools
BRAVE_SEARCH_API_KEY=
PERPLEXITY_API_KEY=
RESEARCH_EMAIL=research@example.org

# Optional - prosoche daemon
PROSOCHE_GATEWAY_TOKEN=
PROSOCHE_CALENDAR_PERSONAL=
PROSOCHE_CALENDAR_FAMILY=
PROSOCHE_CALENDAR_WORK=

# Optional - browser automation
CHROMIUM_PATH=/usr/bin/chromium
