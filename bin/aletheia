#!/usr/bin/env bash
# aletheia — unified CLI for the Aletheia gateway

set -euo pipefail

# Require bash 3.2+ — macOS ships 3.2; associative arrays need 4.0+ (removed below)
_bash_major="${BASH_VERSION%%.*}"
_bash_minor="${BASH_VERSION#*.}"
_bash_minor="${_bash_minor%%.*}"
if [[ "$_bash_major" -lt 3 ]] || { [[ "$_bash_major" -eq 3 ]] && [[ "$_bash_minor" -lt 2 ]]; }; then
  echo "Error: Aletheia requires bash 3.2+. You have $BASH_VERSION." >&2
  exit 1
fi
unset _bash_major _bash_minor

# Resolve ALETHEIA_HOME by following this script's symlink back to the repo root
_realpath() {
  if command -v realpath &>/dev/null; then
    realpath "$1"
  else
    python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1"
  fi
}
SCRIPT_PATH="$(_realpath "${BASH_SOURCE[0]}")"
ALETHEIA_HOME="${ALETHEIA_HOME:-$(dirname "$(dirname "$SCRIPT_PATH")")}"

ENTRY="$ALETHEIA_HOME/infrastructure/runtime/dist/entry.mjs"
ALETHEIA_CONFIG_DIR="${ALETHEIA_CONFIG_DIR:-$HOME/.aletheia}"
PID_FILE="$ALETHEIA_CONFIG_DIR/gateway.pid"
LOG_FILE="$ALETHEIA_CONFIG_DIR/gateway.log"
MEMORY_COMPOSE="$ALETHEIA_HOME/infrastructure/memory/docker-compose.yml"
LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"
GATEWAY_LABEL="com.aletheia.gateway"
MEMORY_LABEL="com.aletheia.memory"

# Parallel indexed arrays — bash 3.2 compatible (associative arrays require bash 4.0+)
MEMORY_HEALTH_KEYS=(qdrant neo4j mem0)
MEMORY_HEALTH_VALS=(
  "http://localhost:6333/healthz"
  "http://localhost:7474"
  "http://localhost:8230/health"
)

_get_health_url() {
  local key="$1" i
  for i in "${!MEMORY_HEALTH_KEYS[@]}"; do
    if [[ "${MEMORY_HEALTH_KEYS[$i]}" == "$key" ]]; then
      printf '%s' "${MEMORY_HEALTH_VALS[$i]}"
      return 0
    fi
  done
  return 1
}

_read_port() {
  python3 -c "
import json, os
path = os.path.join('$ALETHEIA_CONFIG_DIR', 'aletheia.json')
try:
    print(json.load(open(path)).get('gateway', {}).get('port', 18789))
except Exception:
    print(18789)
" 2>/dev/null || echo 18789
}

_compose_cmd() {
  if command -v podman &>/dev/null; then
    echo "podman compose"
  elif command -v docker &>/dev/null; then
    echo "docker compose"
  else
    echo ""
  fi
}

_gateway_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

_write_compose_env() {
  local data_dir="${ALETHEIA_DATA:-$HOME/.aletheia/data}"
  mkdir -p "$data_dir/qdrant" "$data_dir/neo4j"
  # Write .env for Docker Desktop macOS compat (env var expansion regression in 4.40.0)
  printf 'ALETHEIA_DATA=%s\n' "$data_dir" > "$(dirname "$MEMORY_COMPOSE")/.env"
}

_start_memory() {
  _write_compose_env    # resolve path, write .env, warn if old location exists
  local compose_cmd
  compose_cmd="$(_compose_cmd)"

  if [[ -z "$compose_cmd" ]] || [[ ! -f "$MEMORY_COMPOSE" ]]; then
    return 0
  fi

  echo "Memory services:"
  $compose_cmd -f "$MEMORY_COMPOSE" up -d 2>/dev/null || true
  sleep 2

  local all_ok=true
  for svc in qdrant neo4j; do
    local url; url="$(_get_health_url "$svc")"
    if curl -sf "$url" >/dev/null 2>&1; then
      printf "  %-10s ✓ running\n" "$svc"
    else
      printf "  %-10s ✗ unhealthy — check: %s logs %s\n" "$svc" "$compose_cmd" "$svc"
      all_ok=false
    fi
  done

  if curl -sf "$(_get_health_url mem0)" >/dev/null 2>&1; then
    printf "  %-10s ✓ running\n" "mem0"
  else
    printf "  %-10s - not running (optional)\n" "mem0"
  fi
  echo ""

  if [[ "$all_ok" == "false" ]]; then
    echo "Warning: some memory services failed to start. Gateway will continue."
  fi
}

_stop_memory() {
  local compose_cmd
  compose_cmd="$(_compose_cmd)"
  if [[ -z "$compose_cmd" ]] || [[ ! -f "$MEMORY_COMPOSE" ]]; then
    return 0
  fi
  echo "Stopping memory services..."
  $compose_cmd -f "$MEMORY_COMPOSE" down 2>/dev/null || true
  echo "Memory services stopped."
}

cmd_start() {
  local skip_memory=false memory_only=false  # three modes: default, --no-memory, --memory-only
  for arg in "$@"; do
    [[ "$arg" == "--no-memory" ]] && skip_memory=true
    [[ "$arg" == "--memory-only" ]] && memory_only=true
  done

  if [[ "$memory_only" == "true" ]]; then
    local compose_cmd
    compose_cmd="$(_compose_cmd)"
    if [[ -n "$compose_cmd" ]] && \
       $compose_cmd -f "$MEMORY_COMPOSE" ps -q 2>/dev/null | grep -q .; then
      echo "Memory already running"
      exit 0
    fi
    _start_memory
    return
  fi

  if [[ ! -f "$ENTRY" ]]; then
    echo "Error: not built. Run: cd $ALETHEIA_HOME && ./setup.sh"
    exit 1
  fi

  if _gateway_running; then
    echo "Already running (PID $(cat "$PID_FILE"))"
    exit 0
  fi

  local port
  port="$(_read_port)"

  if command -v lsof &>/dev/null && lsof -i ":$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
    echo "Error: port $port already in use by another process"
    exit 1
  fi

  mkdir -p "$ALETHEIA_CONFIG_DIR"

  [[ "$skip_memory" == "false" ]] && _start_memory

  ALETHEIA_ROOT="$ALETHEIA_HOME" \
  ALETHEIA_CONFIG_DIR="$ALETHEIA_CONFIG_DIR" \
    node "$ENTRY" gateway start >> "$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"

  echo -n "Starting gateway"
  for _ in $(seq 1 15); do
    if ! _gateway_running; then
      echo ""
      echo "Error: gateway crashed on startup. Run: aletheia logs"
      rm -f "$PID_FILE"
      exit 1
    fi
    if curl -sf "http://localhost:$port/health" >/dev/null 2>&1; then
      echo ""
      echo "Aletheia running → http://localhost:$port"
      if command -v xdg-open &>/dev/null; then
        xdg-open "http://localhost:$port" 2>/dev/null &
      elif command -v open &>/dev/null; then
        open "http://localhost:$port" 2>/dev/null &
      fi
      return 0
    fi
    echo -n "."
    sleep 1
  done

  echo ""
  echo "Error: gateway did not become ready. Run: aletheia logs"
  exit 1
}

cmd_stop() {
  local stop_all=false
  for arg in "$@"; do
    [[ "$arg" == "--all" ]] && stop_all=true
  done

  if _gateway_running; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
    echo "Gateway stopped."
  else
    echo "Gateway not running."
  fi

  [[ "$stop_all" == "true" ]] && _stop_memory
}

cmd_restart() {
  cmd_stop "$@"
  sleep 1
  cmd_start "$@"
}

cmd_logs() {
  local follow=false
  for arg in "$@"; do
    [[ "$arg" == "-f" || "$arg" == "--follow" ]] && follow=true
  done

  if [[ ! -f "$LOG_FILE" ]]; then
    echo "No log file at $LOG_FILE"
    exit 1
  fi

  if [[ "$follow" == "true" ]]; then
    tail -f "$LOG_FILE"
  else
    tail -100 "$LOG_FILE"
  fi
}

cmd_install() {
  local install_dir="$HOME/.local/bin"
  mkdir -p "$install_dir"
  chmod +x "$ALETHEIA_HOME/bin/aletheia"
  ln -sf "$ALETHEIA_HOME/bin/aletheia" "$install_dir/aletheia"
  echo "Installed: $install_dir/aletheia → $ALETHEIA_HOME/bin/aletheia"

  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$install_dir"; then
    echo ""
    echo "Add to PATH (add to your shell profile):"
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo "  # Fish: fish_add_path ~/.local/bin"
  fi
}

_launchd_loaded() {
  launchctl print "gui/$(id -u)/$1" >/dev/null 2>&1
}

_install_plist() {
  local label="$1"
  local node_bin
  node_bin="$(command -v node 2>/dev/null)"
  if [[ -z "$node_bin" ]]; then
    echo "✗ node not found in PATH — install Node.js first" >&2
    exit 1
  fi
  local aletheia_path config_dir plist_path template dest err
  aletheia_path="$(_realpath "$ALETHEIA_HOME")"
  config_dir="$(_realpath "$ALETHEIA_CONFIG_DIR")"
  plist_path="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  template="$aletheia_path/config/services/${label}.plist"
  dest="$LAUNCH_AGENTS_DIR/${label}.plist"
  mkdir -p "$LAUNCH_AGENTS_DIR"
  mkdir -p "$config_dir/logs"
  if ! sed \
    -e "s|__NODE_BIN__|${node_bin}|g" \
    -e "s|__ALETHEIA_HOME__|${aletheia_path}|g" \
    -e "s|__ALETHEIA_CONFIG_DIR__|${config_dir}|g" \
    -e "s|__PATH__|${plist_path}|g" \
    "$template" > "$dest"; then
    echo "✗ Failed to install ${label}.plist — check template at $template" >&2
    exit 1
  fi
  chmod 644 "$dest"
}

_cmd_enable_mac() {
  if _launchd_loaded "$GATEWAY_LABEL" && _launchd_loaded "$MEMORY_LABEL"; then
    echo "Already enabled"
    exit 0
  fi
  _install_plist "$GATEWAY_LABEL"
  _install_plist "$MEMORY_LABEL"
  local err
  if ! err="$(launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENTS_DIR/${GATEWAY_LABEL}.plist" 2>&1)"; then
    echo "✗ Failed to register gateway: ${err}" >&2
    echo "  Try: launchctl bootstrap gui/$(id -u) $LAUNCH_AGENTS_DIR/${GATEWAY_LABEL}.plist" >&2
    exit 1
  fi
  if ! err="$(launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENTS_DIR/${MEMORY_LABEL}.plist" 2>&1)"; then
    echo "✗ Failed to register memory: ${err}" >&2
    echo "  Try: launchctl bootstrap gui/$(id -u) $LAUNCH_AGENTS_DIR/${MEMORY_LABEL}.plist" >&2
    exit 1
  fi
  echo "✓ Aletheia enabled — starts at login"
}

_cmd_enable_linux() {
  local systemd_dir="$HOME/.config/systemd/user"
  mkdir -p "$systemd_dir"
  local compose_cmd aletheia_path node_bin
  compose_cmd="$(_compose_cmd)"
  aletheia_path="$(_realpath "$ALETHEIA_HOME")"
  node_bin="$(command -v node 2>/dev/null)"
  if [[ -z "$node_bin" ]]; then
    echo "✗ node not found in PATH — install Node.js first" >&2
    exit 1
  fi
  sed \
    -e "s|__ALETHEIA_HOME__|${aletheia_path}|g" \
    -e "s|__COMPOSE_CMD__|${compose_cmd}|g" \
    "$aletheia_path/config/services/aletheia-memory.service" \
    > "$systemd_dir/aletheia-memory.service"
  sed \
    -e "s|__NODE_BIN__|${node_bin}|g" \
    -e "s|__ALETHEIA_HOME__|${aletheia_path}|g" \
    "$aletheia_path/config/services/aletheia.service" \
    > "$systemd_dir/aletheia.service"
  systemctl --user daemon-reload
  if systemctl --user is-enabled aletheia-memory 2>/dev/null | grep -q "^enabled$"; then
    echo "Already enabled"
    exit 0
  fi
  systemctl --user enable aletheia-memory aletheia
  echo "✓ Aletheia enabled — starts at login"
}

cmd_enable() {
  local os; os="$(uname)"
  case "$os" in
    Darwin) _cmd_enable_mac ;;
    Linux)  _cmd_enable_linux ;;
    *) echo "✗ Boot persistence not supported on $os" >&2; exit 1 ;;
  esac
}

_cmd_disable_mac() {
  if ! _launchd_loaded "$GATEWAY_LABEL" && ! _launchd_loaded "$MEMORY_LABEL"; then
    echo "Already disabled"
    exit 0
  fi
  if _gateway_running; then
    printf "Gateway is running. Stop it now? [y/N] "
    read -r answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      cmd_stop
    fi
  fi
  launchctl bootout "gui/$(id -u)/${GATEWAY_LABEL}" 2>/dev/null || true
  launchctl bootout "gui/$(id -u)/${MEMORY_LABEL}" 2>/dev/null || true
  rm -f "$LAUNCH_AGENTS_DIR/${GATEWAY_LABEL}.plist"
  rm -f "$LAUNCH_AGENTS_DIR/${MEMORY_LABEL}.plist"
  echo "✓ Aletheia disabled — will not start at login"
}

_cmd_disable_linux() {
  if ! systemctl --user is-enabled aletheia-memory 2>/dev/null | grep -q "^enabled$"; then
    echo "Already disabled"
    exit 0
  fi
  if _gateway_running; then
    printf "Gateway is running. Stop it now? [y/N] "
    read -r answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      cmd_stop
    fi
  fi
  systemctl --user disable aletheia-memory aletheia 2>/dev/null || true
  systemctl --user daemon-reload
  echo "✓ Aletheia disabled — will not start at login"
}

cmd_disable() {
  local os; os="$(uname)"
  case "$os" in
    Darwin) _cmd_disable_mac ;;
    Linux)  _cmd_disable_linux ;;
    *) echo "✗ Boot persistence not supported on $os" >&2; exit 1 ;;
  esac
}

cmd_help() {
  cat <<EOF
aletheia — unified CLI for the Aletheia gateway

Lifecycle:
  start [--no-memory|--memory-only]  Start gateway+memory, gateway only, or memory only
  stop [--all]           Stop gateway (--all also stops memory containers)
  restart                Stop then start
  logs [-f]              Show gateway logs (-f to follow)
  tui                    Launch terminal UI
  enable                 Register boot persistence (launchd on Mac, systemd on Linux)
  disable                Remove boot persistence

Admin (requires running gateway):
  status                 System health and agent list
  doctor [--fix]         Validate config and connectivity
  send -a <id> -m "…"   Send message to agent
  sessions [-a <id>]     List sessions
  cron list|trigger      Manage cron jobs
  update [version]       Self-update (--edge, --check, --rollback)
  agent create           Scaffold new agent
  plugins list           List loaded plugins

Other:
  install                (Re)install CLI to ~/.local/bin
  help                   Show this help

Environment:
  ALETHEIA_HOME          Override repo root (default: resolved from script location)
  ALETHEIA_CONFIG_DIR    Override config directory (default: ~/.aletheia)
EOF
}

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  start)    cmd_start "$@" ;;
  stop)     cmd_stop "$@" ;;
  restart)  cmd_restart "$@" ;;
  logs)     cmd_logs "$@" ;;
  tui)      exec node "$ENTRY" tui "$@" ;;
  install)  cmd_install ;;
  enable)   cmd_enable "$@" ;;
  disable)  cmd_disable "$@" ;;
  ""|-h|--help|help) cmd_help ;;
  *)        exec node "$ENTRY" "$COMMAND" "$@" ;;
esac
