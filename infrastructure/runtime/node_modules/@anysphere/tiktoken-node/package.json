{
  "name": "@anysphere/tiktoken-node",
  "version": "0.2.1",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "tiktoken-node.node",
    "tiktoken-node.*.node",
    "package.json"
  ],
  "napi": {
    "name": "tiktoken-node",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-pc-windows-msvc",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.16.2",
    "ava": "^5.1.1",
    "wireit": "^0.14.0"
  },
  "engines": {
    "node": ">= 18.15.0"
  },
  "wireit": {
    "build": {
      "clean": "if-file-deleted",
      "command": "napi build --platform --release",
      "files": [
        "src/**",
        "Cargo.toml",
        "Cargo.lock",
        "build.rs"
      ],
      "output": [
        "tiktoken-node.*.node"
      ]
    }
  },
  "optionalDependencies": {
    "@anysphere/tiktoken-node-win32-x64-msvc": "0.2.1",
    "@anysphere/tiktoken-node-darwin-x64": "0.2.1",
    "@anysphere/tiktoken-node-linux-x64-gnu": "0.2.1",
    "@anysphere/tiktoken-node-darwin-arm64": "0.2.1",
    "@anysphere/tiktoken-node-win32-arm64-msvc": "0.2.1",
    "@anysphere/tiktoken-node-linux-arm64-gnu": "0.2.1"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "wireit",
    "build:debug": "napi build --platform",
    "universal": "napi universal",
    "version": "napi version"
  }
}