RUST/pub-visibility:crates/diaporeia/src/state.rs
RUST/pub-visibility:crates/diaporeia/src/transport.rs

# WHY: std::sync::Mutex is intentional — lock guard is never held across await
# points (O(1) arithmetic only). Already documented with inline WHY comment.
RUST/std-mutex-in-async:crates/diaporeia/src/rate_limit.rs

# WHY: .expect() on mutex lock is the correct choice — poisoned mutex is
# unrecoverable. Already suppressed via #[expect(clippy::expect_used)].
RUST/expect:crates/diaporeia/src/rate_limit.rs

