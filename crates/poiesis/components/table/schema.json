{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "headers", "rows"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "headers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "rows": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "string" } },
      "minItems": 1
    },
    "caption": { "type": "string" }
  }
}
