<div class="zone-header">
  <h2 style="font-family:var(--font-heading);font-size:1.75rem;font-weight:700;color:var(--theme-text);">{{ fields.title }}</h2>
</div>
<div class="zone-content" style="display:flex;flex-direction:column;justify-content:center;">
  {% for event in fields.events %}
  <div style="display:flex;align-items:flex-start;gap:1rem;padding:0.5rem 0;">
    <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:1.25rem;">
      <div style="width:0.75rem;height:0.75rem;border-radius:50%;background:var(--theme-primary);flex-shrink:0;"></div>
      {% if not loop.last %}
      <div style="width:2px;flex:1;background:var(--theme-secondary);margin-top:2px;min-height:1rem;"></div>
      {% endif %}
    </div>
    <div style="flex:1;padding-bottom:0.25rem;">
      {% if event.date %}
      <div style="font-family:var(--font-body);font-size:0.75rem;font-weight:600;color:var(--theme-primary);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.1rem;">{{ event.date }}</div>
      {% endif %}
      <div style="font-family:var(--font-body);font-size:1rem;font-weight:600;color:var(--theme-text);">{{ event.label }}</div>
      {% if event.detail %}
      <div style="font-family:var(--font-body);font-size:0.875rem;color:var(--theme-text);opacity:0.65;margin-top:0.15rem;">{{ event.detail }}</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
