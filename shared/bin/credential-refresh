#!/usr/bin/env python3
"""credential-refresh — Auto-refresh Anthropic OAuth tokens before expiry.

Reads credential files, checks expiry, refreshes via Anthropic's OAuth endpoint,
writes updated tokens back. Designed to run as a systemd timer or cron job.

Usage:
  credential-refresh              # Check and refresh if needed
  credential-refresh --force      # Force refresh regardless of expiry
  credential-refresh --daemon     # Run continuously, refreshing proactively
  credential-refresh --status     # Show current token status

Token endpoint: https://console.anthropic.com/v1/oauth/token
Client ID: Claude Code production OAuth client
"""

import argparse
import json
import os
import signal
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

import urllib.request
import urllib.error

# Claude Code production OAuth client ID (from cli.js)
CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
TOKEN_URL = "https://console.anthropic.com/v1/oauth/token"

# Refresh when token has less than this many seconds left
_config = {"threshold": 3600, "interval": 300}

# Credential file locations
ALETHEIA_CRED = Path.home() / ".aletheia" / "credentials" / "anthropic.json"
CLAUDE_CODE_CRED = Path.home().parent / "ck" / ".claude" / ".credentials.json"


def log(msg: str, level: str = "INFO"):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{ts}] [{level}] {msg}", file=sys.stderr)


def load_aletheia_creds() -> dict | None:
    """Load Aletheia credential file."""
    try:
        with open(ALETHEIA_CRED) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError) as e:
        log(f"Cannot read {ALETHEIA_CRED}: {e}", "ERROR")
        return None


def token_status(creds: dict) -> tuple[bool, int]:
    """Returns (is_expired, seconds_remaining)."""
    expires_at = creds.get("expiresAt", 0)
    now_ms = int(time.time() * 1000)
    remaining_ms = expires_at - now_ms
    remaining_s = remaining_ms // 1000
    return remaining_s <= 0, remaining_s


def needs_refresh(creds: dict) -> bool:
    """Check if token needs refresh (expired or within threshold)."""
    expired, remaining = token_status(creds)
    return expired or remaining < _config["threshold"]


def refresh_token(refresh_tok: str) -> dict | None:
    """POST to Anthropic OAuth endpoint to get new tokens."""
    payload = json.dumps({
        "grant_type": "refresh_token",
        "refresh_token": refresh_tok,
        "client_id": CLIENT_ID,
    }).encode()

    req = urllib.request.Request(
        TOKEN_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read())
            return data
    except urllib.error.HTTPError as e:
        body = e.read().decode() if e.fp else ""
        log(f"Refresh failed: HTTP {e.code} — {body}", "ERROR")
        return None
    except Exception as e:
        log(f"Refresh failed: {e}", "ERROR")
        return None


def save_aletheia_creds(creds: dict):
    """Write updated credentials to Aletheia file."""
    ALETHEIA_CRED.parent.mkdir(parents=True, exist_ok=True)
    with open(ALETHEIA_CRED, "w") as f:
        json.dump(creds, f, indent=2)
    os.chmod(ALETHEIA_CRED, 0o600)
    log(f"Updated {ALETHEIA_CRED}")


def update_claude_code_creds(access_token: str, refresh_tok: str, expires_at_ms: int, scopes: list[str]):
    """Update Claude Code's credential file if accessible."""
    if not CLAUDE_CODE_CRED.exists():
        log(f"Claude Code creds not found at {CLAUDE_CODE_CRED} — skipping", "WARN")
        return

    try:
        new_creds = {
            "claudeAiOauth": {
                "accessToken": access_token,
                "refreshToken": refresh_tok,
                "expiresAt": expires_at_ms,
                "scopes": scopes,
                "subscriptionType": "max",
                "rateLimitTier": "default_claude_max_5x",
            }
        }
        with open(CLAUDE_CODE_CRED, "w") as f:
            json.dump(new_creds, f)
        log(f"Updated {CLAUDE_CODE_CRED}")
    except PermissionError:
        log(f"Permission denied writing {CLAUDE_CODE_CRED} — needs sudo", "WARN")
    except Exception as e:
        log(f"Failed to update Claude Code creds: {e}", "WARN")


def do_refresh(force: bool = False) -> bool:
    """Main refresh logic. Returns True if refresh succeeded or wasn't needed."""
    creds = load_aletheia_creds()
    if not creds:
        return False

    expired, remaining = token_status(creds)

    if not force and not needs_refresh(creds):
        log(f"Token valid — {remaining}s remaining ({remaining // 3600}h {(remaining % 3600) // 60}m)")
        return True

    refresh_tok = creds.get("refreshToken")
    if not refresh_tok:
        log("No refreshToken in credential file — cannot refresh", "ERROR")
        return False

    status = "expired" if expired else f"expiring in {remaining}s"
    log(f"Token {status} — refreshing...")

    result = refresh_token(refresh_tok)
    if not result:
        return False

    new_access = result["access_token"]
    new_refresh = result["refresh_token"]
    expires_in = result.get("expires_in", 28800)
    scopes = result.get("scope", "").split()
    expires_at_ms = int((time.time() + expires_in) * 1000)

    # Update Aletheia creds
    creds["token"] = new_access
    creds["refreshToken"] = new_refresh
    creds["expiresAt"] = expires_at_ms
    if scopes:
        creds["scopes"] = scopes
    save_aletheia_creds(creds)

    # Update Claude Code creds (best-effort)
    update_claude_code_creds(new_access, new_refresh, expires_at_ms, scopes)

    log(f"Refresh successful — new token expires in {expires_in}s ({expires_in // 3600}h)")
    return True


def show_status():
    """Display current token status."""
    creds = load_aletheia_creds()
    if not creds:
        print("ERROR: Cannot read credential file")
        return

    expired, remaining = token_status(creds)
    expires_at = creds.get("expiresAt", 0)
    expires_dt = datetime.fromtimestamp(expires_at / 1000, tz=timezone.utc)

    token = creds.get("token", "")
    refresh = creds.get("refreshToken", "")

    print(f"Credential file: {ALETHEIA_CRED}")
    print(f"Token:           {token[:30]}..." if token else "Token:           MISSING")
    print(f"Refresh token:   {refresh[:30]}..." if refresh else "Refresh token:   MISSING")
    print(f"Expires:         {expires_dt.isoformat()}")
    print(f"Remaining:       {remaining}s ({remaining // 3600}h {(remaining % 3600) // 60}m)")
    print(f"Status:          {'EXPIRED' if expired else 'NEEDS REFRESH' if needs_refresh(creds) else 'VALID'}")
    print(f"Subscription:    {creds.get('subscriptionType', 'unknown')}")
    print(f"Scopes:          {', '.join(creds.get('scopes', []))}")


def run_daemon():
    """Run continuously, checking and refreshing proactively."""
    log(f"Daemon started — checking every {_config["interval"]}s, refreshing {_config["threshold"]}s before expiry")

    running = True

    def handle_signal(signum, frame):
        nonlocal running
        log(f"Received signal {signum} — shutting down")
        running = False

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    while running:
        try:
            do_refresh()
        except Exception as e:
            log(f"Refresh cycle error: {e}", "ERROR")

        # Sleep in small increments so we can catch signals
        for _ in range(_config["interval"]):
            if not running:
                break
            time.sleep(1)

    log("Daemon stopped")


def main():
    parser = argparse.ArgumentParser(description="Auto-refresh Anthropic OAuth tokens")
    parser.add_argument("--force", action="store_true", help="Force refresh regardless of expiry")
    parser.add_argument("--daemon", action="store_true", help="Run continuously")
    parser.add_argument("--status", action="store_true", help="Show token status")
    parser.add_argument("--threshold", type=int, default=_config["threshold"],
                        help=f"Seconds before expiry to trigger refresh (default: {_config["threshold"]})")
    args = parser.parse_args()

    _config["threshold"] = args.threshold

    if args.status:
        show_status()
    elif args.daemon:
        run_daemon()
    else:
        success = do_refresh(force=args.force)
        sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
